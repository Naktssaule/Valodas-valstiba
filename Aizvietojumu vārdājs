          <p><b><span class="moze-large"><i style=""><span style="color: #000000">A deadname ---&gt;</span></i><span style="color: #00a022">&nbsp;Ne</span><span style="color: #000000">(ļauž)</span><span style="color: #00a022">vārds</span><span style="color: #000000">,</span><span style="color: #00a022"> </span></span><span style="color: #000000" class="moze-tiny">(ļaudieša/ļaudeņa)</span><span class="moze-large"><span style="color: #00a022"> nevārds</span><br><span style="color: #000000"><i>To deadname</i> ---&gt;</span><span style="color: #00a022"> Dēvēt nevārdā</span><span style="color: #000000">, </span><span style="color: #00a022">nevārdot</span></span></b></p><p><b><span class="moze-large"><span style="color: #000000">Detaļa ---&gt; </span><span style="color: #00a022">Sīkdaļa&nbsp;</span></span><span style="color: #000000"><span class="moze-tiny">[</span><a href="https://tezaurs.lv/s%C4%ABkda%C4%BCa" target="_blank" rel="nofollow"><span class="moze-tiny">V-T</span></a><span class="moze-tiny">]</span></span><span class="moze-large"><span style="color: #000000">,&nbsp;</span><span style="color: #00a022">sastāvdaļa</span><span style="color: #000000"> | </span><span style="color: #00a022">Daļa</span><span style="color: #000000"> / </span><span style="color: #00a022">Sīkums</span><br><span style="color: #000000">Detalizēt --&gt; (Sa)</span><span style="color: #00a022">sīkdaļot </span></span><span style="color: #000000"><span class="moze-tiny">[</span><a href="http://vuordineica.lv/meklet.php?vrd=detaliz%C4%93t&amp;s=1&amp;sais=0" target="_blank" rel="nofollow"><span class="moze-tiny">V-LTG</span></a><span class="moze-tiny">]</span></span><span class="moze-large"><br><span style="color: #000000">Detalizēšana ---&gt; </span><span style="color: #00a022">Sīkdaļošana</span><br><span style="color: #000000">Detalizējums ---&gt; </span><span style="color: #00a022">Sīkdaļojums</span><br></span><span style="color: #000000"><span class="moze-large">Detalizǣts</span></span><spa